# SMTP Configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email settings
FROM_EMAIL=your-email@gmail.com
TO_EMAIL=your-email@gmail.com

# CORS settings (frontend URL)
FRONTEND_URL=http://localhost:3000

# Server settings
HOST=0.0.0.0
PORT=8000

# Database Configuration (NeonDB PostgreSQL)
# Get your connection string from https://neon.tech
# Format: postgresql+asyncpg://username:password@ep-xxx.neon.tech/database?sslmode=require
DATABASE_URL=postgresql+asyncpg://username:password@ep-xxx.neon.tech/neondb?sslmode=require

# Google Gemini API Key
# Get your free API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
